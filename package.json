{
  "name": "daytiles-obsidian",
  "version": "0.1.0",
  "description": "Render daytiles SVG calendars from code blocks in Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/copy-meta.mjs",
    "copy-meta": "node scripts/copy-meta.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "calendar",
    "daytiles"
  ],
  "author": "omi",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "daytiles": "github:Chamartin3/daytiles#636a5f88fa0cbd05e9dcca39b1280b5c149c9039",
    "js-yaml": "^4.1.0"
  }
}
